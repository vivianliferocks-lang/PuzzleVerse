{"batchcomplete": "", "query": {"pages": {"95757255": {"pageid": 95757255, "ns": 6, "title": "File:Emanuel Celler Painting.jpg", "imagerepository": "local", "imageinfo": [{"size": 71309, "width": 256, "height": 310, "canonicaltitle": "File:Emanuel Celler Painting.jpg", "url": "https://upload.wikimedia.org/wikipedia/commons/0/0f/Emanuel_Celler_Painting.jpg", "descriptionurl": "https://commons.wikimedia.org/wiki/File:Emanuel_Celler_Painting.jpg", "descriptionshorturl": "https://commons.wikimedia.org/w/index.php?curid=95757255", "extmetadata": {"DateTime": {"value": "2020-11-03 01:33:25", "source": "mediawiki-metadata", "hidden": ""}, "ObjectName": {"value": "Emanuel Celler Painting", "source": "mediawiki-metadata"}, "CommonsMetadataExtension": {"value": 1.2, "source": "extension", "hidden": ""}, "Categories": {"value": "United States House of Representatives|Emanuel Celler|PD US Congress|Paintings of men of the United States", "source": "commons-categories", "hidden": ""}, "Assessments": {"value": "", "source": "commons-categories", "hidden": ""}, "ImageDescription": {"value": "Emanuel Celler’s Judiciary Committee Chairman portrait was unveiled on March 19, 1963, coinciding with his 40th anniversary in the House of Representatives. Joseph Margulies—an Austrian-born, Massachusetts based painter and printmaker—received the commission. In describing his experience of having a portrait made, Celler felt that the artist created a “painted biography,” reflecting his character and personality. Margulies, who studied at the National Academy of Design, Cooper Union, and the Art Students League, also painted portraits of Albert Einstein, President Eisenhower, and Franklin Delano Roosevelt.", "source": "commons-desc-page"}, "DateTimeOriginal": {"value": "1963-03-19", "source": "commons-desc-page"}, "Credit": {"value": "<a rel=\"nofollow\" class=\"external free\" href=\"https://history.house.gov/Collection/Listing/2002/2002-012-005/\">https://history.house.gov/Collection/Listing/2002/2002-012-005/</a>", "source": "commons-desc-page"}, "Artist": {"value": "Joseph Margulies", "source": "commons-desc-page"}, "LicenseShortName": {"value": "Public domain", "source": "commons-desc-page", "hidden": ""}, "UsageTerms": {"value": "Public domain", "source": "commons-desc-page"}, "AttributionRequired": {"value": "false", "source": "commons-desc-page", "hidden": ""}, "Copyrighted": {"value": "False", "source": "commons-desc-page", "hidden": ""}, "Restrictions": {"value": "", "source": "commons-desc-page", "hidden": ""}, "License": {"value": "pd", "source": "commons-templates", "hidden": ""}}, "mime": "image/jpeg"}]}}}}