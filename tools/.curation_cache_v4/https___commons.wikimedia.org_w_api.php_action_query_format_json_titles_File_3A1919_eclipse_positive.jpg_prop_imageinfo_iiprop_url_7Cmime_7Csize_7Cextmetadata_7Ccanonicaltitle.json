{"continue": {"iistart": "2017-04-30T23:05:34Z", "continue": "||"}, "query": {"pages": {"182028": {"pageid": 182028, "ns": 6, "title": "File:1919 eclipse positive.jpg", "imagerepository": "local", "imageinfo": [{"size": 73054, "width": 490, "height": 533, "canonicaltitle": "File:1919 eclipse positive.jpg", "url": "https://upload.wikimedia.org/wikipedia/commons/3/37/1919_eclipse_positive.jpg", "descriptionurl": "https://commons.wikimedia.org/wiki/File:1919_eclipse_positive.jpg", "descriptionshorturl": "https://commons.wikimedia.org/w/index.php?curid=182028", "extmetadata": {"DateTime": {"value": "2023-07-03 13:47:53", "source": "mediawiki-metadata", "hidden": ""}, "ObjectName": {"value": "1919 eclipse positive", "source": "mediawiki-metadata"}, "CommonsMetadataExtension": {"value": 1.2, "source": "extension", "hidden": ""}, "Categories": {"value": "Arthur Stanley Eddington|Gravitational lensing|Solar eclipse of 1919 May 29|PD-old-80-expired|CC-PD-Mark|1919 in physics|1919 Greenwich Observatory Sobral expedition|Famous experiments", "source": "commons-categories", "hidden": ""}, "Assessments": {"value": "", "source": "commons-categories", "hidden": ""}, "ImageDescription": {"value": "<div>Caption:  \n<div lang=\"en\" style=\"direction:ltr; text-align:left;\"><div style=\"font-style:italic;\">From the report of Sir <a href=\"https://en.wikipedia.org/wiki/Arthur_Eddington\" class=\"extiw\" title=\"w:Arthur Eddington\">Arthur Eddington</a> on the expedition to verify <a href=\"https://en.wikipedia.org/wiki/Albert_Einstein\" class=\"extiw\" title=\"w:Albert Einstein\">Albert Einstein</a>'s prediction of the bending of light around the sun.\n<dl><dd>In Plate 1 is given a half-tone reproduction of one of the negatives taken with the 4-inch lens at Sobral. This shows the position of the stars, and, as far as possible in a reproduction of this kind, the character of the images, as there has been no retouching. A number of photographic prints have been made and applications for these from astronomers, who wish to assure themselves of the quality of the photographs, will be considered as as far as possible acceded to.</dd></dl></div></div></div>", "source": "commons-desc-page"}, "DateTimeOriginal": {"value": "1919-05-29", "source": "commons-desc-page"}, "Credit": {"value": "<cite style=\"font-style:normal\">(in English) F. W. Dyson, A. S. Eddington, and C. Davidson (1920). \"A Determination of the Deflection of Light by the Sun's Gravitational Field, from Observations Made at the Total Eclipse of May 29, 1919\". <i><a href=\"https://en.wikipedia.org/wiki/Philosophical_Transactions_of_the_Royal_Society_A\" class=\"extiw\" title=\"w:Philosophical Transactions of the Royal Society A\">Philosophical Transactions of the Royal Society A</a></i>: 332. <span lang=\"en\" dir=\"ltr\"><a href=\"https://en.wikipedia.org/wiki/ISSN\" class=\"extiw\" title=\"en:ISSN\"><span lang=\"en\" dir=\"ltr\">ISSN</span></a></span> <a rel=\"nofollow\" class=\"external text\" href=\"https://www.worldcat.org/issn/1364-503X\">1364-503X</a>.</cite>", "source": "commons-desc-page"}, "Artist": {"value": "<bdi><a href=\"https://en.wikipedia.org/wiki/en:Frank_Watson_Dyson\" class=\"extiw\" title=\"w:en:Frank Watson Dyson\"><span title=\"English astronomer and Astronomer Royal (1868–1939)\">Frank Watson Dyson</span></a></bdi> / <bdi><a href=\"https://en.wikipedia.org/wiki/en:Arthur_Eddington\" class=\"extiw\" title=\"w:en:Arthur Eddington\"><span title=\"British astrophysicist (1882-1944)\">Arthur Eddington</span></a></bdi> / <bdi><a href=\"https://www.wikidata.org/wiki/Q21165602\" class=\"extiw\" title=\"d:Q21165602\"><span title=\"astronomer; (1875 - 1970)\">Charles Rundle Davidson</span></a></bdi>", "source": "commons-desc-page"}, "LicenseShortName": {"value": "Public domain", "source": "commons-desc-page", "hidden": ""}, "UsageTerms": {"value": "Public domain", "source": "commons-desc-page"}, "AttributionRequired": {"value": "false", "source": "commons-desc-page", "hidd