{"continue": {"iistart": "2008-05-12T15:10:28Z", "continue": "||"}, "query": {"pages": {"2169848": {"pageid": 2169848, "ns": 6, "title": "File:Mariecurie.jpg", "imagerepository": "local", "imageinfo": [{"size": 243214, "width": 1536, "height": 1987, "canonicaltitle": "File:Mariecurie.jpg", "url": "https://upload.wikimedia.org/wikipedia/commons/d/d9/Mariecurie.jpg", "descriptionurl": "https://commons.wikimedia.org/wiki/File:Mariecurie.jpg", "descriptionshorturl": "https://commons.wikimedia.org/w/index.php?curid=2169848", "extmetadata": {"DateTime": {"value": "2016-06-30 08:58:00", "source": "mediawiki-metadata", "hidden": ""}, "ObjectName": {"value": "Mariecurie", "source": "mediawiki-metadata"}, "CommonsMetadataExtension": {"value": 1.2, "source": "extension", "hidden": ""}, "Categories": {"value": "Marie Curie|PD US|Featured pictures on Wikipedia, Hebrew|Template Unknown (author)|PD-US missing SDC copyright status|Files with Assessments template missing SDC Commons no value quality assessment", "source": "commons-categories", "hidden": ""}, "Assessments": {"value": "", "source": "commons-categories", "hidden": ""}, "ImageDescription": {"value": "Portrait of <a href=\"//commons.wikimedia.org/wiki/Maria_Sk%C5%82odowska-Curie\" title=\"Maria Skłodowska-Curie\">Maria Skłodowska-Curie</a> (November 7, 1867 – July 4, 1934), sometime prior to 1907. Curie and her husband <a href=\"https://en.wikipedia.org/wiki/Pierre_Curie\" class=\"extiw\" title=\"en:Pierre Curie\">Pierre</a> shared a <a href=\"https://en.wikipedia.org/wiki/Nobel_Prize_in_Physics\" class=\"extiw\" title=\"en:Nobel Prize in Physics\">Nobel Prize in Physics</a> in 1903. Working together, she and her husband isolated <a href=\"https://en.wikipedia.org/wiki/Polonium\" class=\"extiw\" title=\"en:Polonium\">Polonium</a>. Pierre died in 1907, but Marie continued her work, namely with <a href=\"https://en.wikipedia.org/wiki/Radium\" class=\"extiw\" title=\"en:Radium\">Radium</a>, and received a <a href=\"https://en.wikipedia.org/wiki/Nobel_Prize_in_Chemistry\" class=\"extiw\" title=\"en:Nobel Prize in Chemistry\">Nobel Prize in Chemistry</a> in 1911. Her death is mainly attributed to excess exposure to <a href=\"https://en.wikipedia.org/wiki/radiation\" class=\"extiw\" title=\"en:radiation\">radiation</a>.", "source": "commons-desc-page"}, "DateTimeOriginal": {"value": "circa 1898<div style=\"display: none;\">date QS:P,+1898-00-00T00:00:00Z/9,P1480,Q5727902</div>", "source": "commons-desc-page"}, "Credit": {"value": "<a rel=\"nofollow\" class=\"external free\" href=\"http://www.mlahanas.de/Physics/Bios/MarieCurie.html\">http://www.mlahanas.de/Physics/Bios/MarieCurie.html</a>", "source": "commons-desc-page"}, "Artist": {"value": "Unknown author<span style=\"display: none;\">Unknown author</span>", "source": "commons-desc-page"}, "Permission": {"value": "This image might not be in the public domain outside of the United States; this especially applies in the countries and areas that do not apply the <a href=\"https://en.wikipedia.org/wiki/rule_of_the_shorter_term\" class=\"extiw\" title=\"w:rule of the shorter term\">rule of the shorter term</a> for US works, such as Canada, Mainland China (not Hong Kong or Macao), Germany, Mexico, and Switzerland. The creator and year of publication are essential information and must be provided. See <a href=\"https://en.wikipedia.org/wiki/Wikipedia:Public_domain\" class=\"extiw\" title=\"w:Wikipedia:Public domain\">Wikipedia:Public domain</a> and <a href=\"https://en.wikipedia.org/wiki/Wikipedia:Copyrights\" class=\"extiw\" title=\"w:Wikipedia:Copyrights\">Wikipedia:Copyrights</a> for more details.", "source": "commons-desc-page", "hidden": ""}, "LicenseShortName": {"value": "Public domain", "source": "commons-desc-page", "hidden": ""}, "UsageTerms": {"value": "Public domain", "source": "commons-desc-page"}, "AttributionRequired": {"value": "false", "source": "commons-desc-page", "hidden": ""}, "Copyrighted": {"value": "False", "source": "c