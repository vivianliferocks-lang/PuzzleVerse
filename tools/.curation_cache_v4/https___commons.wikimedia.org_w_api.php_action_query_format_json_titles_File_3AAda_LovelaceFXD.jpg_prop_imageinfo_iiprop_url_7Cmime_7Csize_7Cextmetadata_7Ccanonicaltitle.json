velace was an avid mathematician and is often called the first computer programmer, after she wrote an algorithm for <a href=\"https://en.wikipedia.org/wiki/Charles_Babbage\" class=\"extiw\" title=\"en:Charles Babbage\">Charles Babbage</a>'s <a href=\"https://en.wikipedia.org/wiki/Analytical_Engine\" class=\"extiw\" title=\"en:Analytical Engine\">Analytical Engine</a>.</div>", "source": "commons-desc-page"}, "DateTimeOriginal": {"value": "1836 <span class=\"mw-valign-text-top noprint\" typeof=\"mw:File/Frameless\"><a href=\"https://www.wikidata.org/wiki/Q119052629#P571\" title=\"Edit this at Wikidata\"><img alt=\"Edit this at Wikidata\" src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/8/8a/OOjs_UI_icon_edit-ltr-progressive.svg/20px-OOjs_UI_icon_edit-ltr-progressive.svg.png\" decoding=\"async\" width=\"10\" height=\"10\" class=\"mw-file-element\" data-file-width=\"20\" data-file-height=\"20\"></a></span>", "source": "commons-desc-page"}, "Credit": {"value": "This file was derived from:  <a href=\"//commons.wikimedia.org/wiki/File:Ada_Lovelace.jpg\" title=\"File:Ada Lovelace.jpg\">Ada Lovelace.jpg</a>: <span typeof=\"mw:File\"><a href=\"//commons.wikimedia.org/wiki/File:Ada_Lovelace.jpg\" class=\"mw-file-description\"><img src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/8/87/Ada_Lovelace.jpg/120px-Ada_Lovelace.jpg\" decoding=\"async\" width=\"120\" height=\"190\" class=\"mw-file-element\" srcset=\"https://upload.wikimedia.org/wikipedia/commons/thumb/8/87/Ada_Lovelace.jpg/250px-Ada_Lovelace.jpg 2x\" data-file-width=\"3604\" data-file-height=\"5718\"></a></span><br>", "source": "commons-desc-page"}, "LicenseShortName": {"value": "Public domain", "source": "commons-desc-page", "hidden": ""}, "UsageTerms": {"value": "Public domain", "source": "commons-desc-page"}, "AttributionRequired": {"value": "false", "source": "commons-desc-page", "hidden": ""}, "Copyrighted": {"value": "False", "source": "commons-desc-page", "hidden": ""}, "Restrictions": {"valu