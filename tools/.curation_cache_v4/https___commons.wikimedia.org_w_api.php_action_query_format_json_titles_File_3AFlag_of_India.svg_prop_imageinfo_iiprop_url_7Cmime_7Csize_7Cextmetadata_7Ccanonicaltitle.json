{"continue": {"iistart": "2023-02-27T22:40:22Z", "continue": "||"}, "query": {"pages": {"343608": {"pageid": 343608, "ns": 6, "title": "File:Flag of India.svg", "imagerepository": "local", "imageinfo": [{"size": 848, "width": 900, "height": 600, "canonicaltitle": "File:Flag of India.svg", "url": "https://upload.wikimedia.org/wikipedia/commons/4/41/Flag_of_India.svg", "descriptionurl": "https://commons.wikimedia.org/wiki/File:Flag_of_India.svg", "descriptionshorturl": "https://commons.wikimedia.org/w/index.php?curid=343608", "extmetadata": {"DateTime": {"value": "2024-01-17 20:24:36", "source": "mediawiki-metadata", "hidden": ""}, "ObjectName": {"value": "Flag of India", "source": "mediawiki-metadata"}, "CommonsMetadataExtension": {"value": 1.2, "source": "extension", "hidden": ""}, "Categories": {"value": "PD India|With insignia|Images used in valued image sets|Files with derivative versions|SVG flags of India - aspect ratio of 3:2|SVG national flag of India|Valid SVG created with Inkscape:Flags|PD-old missing SDC copyright status|PD flag", "source": "commons-categories", "hidden": ""}, "Assessments": {"value": "valued", "source": "commons-categories", "hidden": ""}, "ImageDescription": {"value": "The <a href=\"https://en.wikipedia.org/wiki/Flag_of_India\" class=\"extiw\" title=\"en:Flag of India\">Flag of India</a>. The colours are saffron, white and green. The navy blue wheel in the center of the flag has a diameter approximately the width of the white band and is called Ashoka's Dharma Chakra, with 24 spokes (after Ashoka, the Great). Each spoke depicts one hour of the day, portraying the prevalence of righteousness all 24 hours of it.", "source": "commons-desc-page"}, "DateTimeOriginal": {"value": "<b>1947-present</b>", "source": "commons-desc-page"}, "Credit": {"value": "<p><span class=\"int-own-work\" lang=\"en\">Own work</span>, based on \n</p>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://www.mha.gov.in/sites/default/files/flagcodeofindia_070214.pdf\">Flag Code of India (2002)</a></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://law.resource.org/pub/in/bis/S12/is.1.1968.pdf\">Specification for the National Flag of India (Cotton Khadi) (amended in 1979)</a></li></ul>\n<ul><li><b>CONSTRUCTION SHEET:</b> <span typeof=\"mw:File\"><a href=\"//commons.wikimedia.org/wiki/File:Flag_of_India_(construction_sheet)_(2-3).svg\" class=\"mw-file-description\"><img src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/0/0b/Flag_of_India_%28construction_sheet%29_%282-3%29.svg/250px-Flag_of_India_%28construction_sheet%29_%282-3%29.svg.png\" decoding=\"async\" width=\"200\" height=\"139\" class=\"mw-file-element\" srcset=\"https://upload.wikimedia.org/wikipedia/commons/thumb/0/0b/Flag_of_India_%28construction_sheet%29_%282-3%29.svg/500px-Flag_of_India_%28construction_sheet%29_%282-3%29.svg.png 2x\" data-file-width=\"1086\" data-file-height=\"754\"></a></span></li></ul>\n<table class=\"infobox wikitable\" lang=\"en\" dir=\"ltr\" style=\"width:360px;\">\n<tbody><tr>\n<th colspan=\"2\" style=\"text-align:center; background-color:#DDD\">Flag of <bdi lang=\"\">India</bdi>*\n</th></tr>\n\n\n\n<tr>\n<td>country</td>\n<td>India\n</td></tr>\n<tr>\n<td>used by</td>\n<td lang=\"\" dir=\"auto\">India\n</td></tr>\n<tr>\n<td>current since</td>\n<td lang=\"\" dir=\"auto\">15 August 1947\n</td></tr>\n<tr>\n<td>created by</td>\n<td lang=\"\" dir=\"auto\">Pingali Venkayya\n</td></tr>\n<tr>\n<td>format</td>\n<td lang=\"\" dir=\"auto\">2:3\n</td></tr>\n<tr>\n<td>shape</td>\n<td lang=\"\" dir=\"auto\">rectangular\n</td></tr>\n<tr lang=\"\" dir=\"auto\">\n<td>FIAV</td>\n<td><span class=\"mw-image-border noviewer skin-invert\" typeof=\"mw:File\"><a href=\"//commons.wikimedia.org/wiki/Category:Vexillological_symbols\" title=\"↑\"><img alt=\"↑\" src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/6/6f/FIAV_111000.svg/40px-FIAV_111000.svg.png\" decoding=\"async\" width=\"23\" height=\"15\" class=\"mw-file-element\" srcset=\"https://upload.wikimedia.org/wikipedia/commons/thumb/6/6f/FIAV_111000.svg/60px-FIAV_111000.svg.png 2x\" data-file-width=\"320\" data-file-height=\"210\"></a></span><a href=\"//commons.wikimedia.org/wiki/Category:Vexillological_symbols\" title=\"Category:Vexillological symbols\">↑</a>\n</td></tr>\n\n\n<tr>\n<td>colours</td>\n<td lang=\"\" dir=\"auto\">orange, white, green, blue\n</td></tr><tr valign=\"middle\">\n<td><span style=\"background-color:#FF671F;border:1px solid darkgray;\" title=\"#FF671F\">    </span> orange</td>\n<td><small><i>rendered as</i></small> <code><a href=\"https://en.wikipedia.org/wiki/RGB_color_model\" class=\"extiw\" title=\"en:RGB color model\">RGB</a> 255 103 <span style=\"visibility:hidden\">0</span>31</code></td></tr><tr valign=\"middle\">\n<td><span style=\"background-color:#FFF;border:1px solid darkgray;\" title=\"#FFF\">    </span> white</td>\n<td><small><i>rendered as</i></small> <code><a href=\"https://en.wikipedia.org/wiki/RGB_color_model\" class=\"extiw\" title=\"en:RGB color model\">RGB</a> 255 255 255</code></td></tr><tr valign=\"middle\">\n<td><span style=\"background-color:#046A38;border:1px solid darkgray;\" title=\"#046A38\">    </span> green</td>\n<td><small><i>rendered as</i></small> <code><a href=\"https://en.wikipedia.org/wiki/RGB_color_model\" class=\"extiw\" title=\"en:RGB color model\">RGB</a> <span style=\"visibility:hidden\">00</span>4 106 <span style=\"visibility:hidden\">0</span>56</code></td></tr> <tr valign=\"middle\">\n<td><span style=\"background-color:#06038D;border:1px solid darkgray;\" title=\"#06038D\">    </span> blue</td>\n<td><small><i>rendered as</i></small> <code><a href=\"https://en.wikipedia.org/wiki/RGB_color_model\" class=\"extiw\" title=\"en:RGB color model\">RGB</a> <span style=\"visibility:hidden\">00</span>6 <span style=\"visibility:hidden\">00</span>3 141</code></td></tr>\n\n<tr>\n<td>other characteristics</td>\n<td lang=\"\" dir=\"auto\">flag has 3 horizontal stripes<br>\n<p>flag contains symbol: <i><a href=\"//commons.wikimedia.org/wiki/File:Ashoka_Chakra.svg\" title=\"File:Ashoka Chakra.svg\">Dharma-chakra</a></i><br>\n</p>\n</td></tr></tbody></table>", "source": "commons-desc-page"}, "Artist": {"value": "<bdi><a href=\"https://en.wikipedia.org/wiki/en:Government_of_India\" class=\"extiw\" title=\"w:en:Government of India\"><span title=\"legislative, executive and judiciary authority of India\">Government of India</span></a>\n</bdi>", "source": "commons-desc-page"}, "LicenseShortName": {"value": "Public domain", "source": "commons-desc-page", "hidden": ""}, "UsageTerms": {"value": "Public domain", "source": "commons-desc-page"}, "AttributionRequired": {"value": "false", "source": "commons-desc-page", "hidden": ""}, "Copyrighted": {"value": "False", "source": "commons-desc-page", "hidden": ""}, "Restrictions": {"value": "insignia", "source": "commons-desc-page", "hidden": ""}, "License": {"value": "pd", "source": "commons-templates", "hidden": ""}}, "mime": "image/svg+xml"}]}}}}