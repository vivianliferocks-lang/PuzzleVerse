{"continue": {"iistart": "2009-01-11T01:15:41Z", "continue": "||"}, "query": {"pages": {"5687346": {"pageid": 5687346, "ns": 6, "title": "File:Darwin restored2.jpg", "imagerepository": "local", "imageinfo": [{"size": 5180035, "width": 3180, "height": 4311, "canonicaltitle": "File:Darwin restored2.jpg", "url": "https://upload.wikimedia.org/wikipedia/commons/b/b6/Darwin_restored2.jpg", "descriptionurl": "https://commons.wikimedia.org/wiki/File:Darwin_restored2.jpg", "descriptionshorturl": "https://commons.wikimedia.org/w/index.php?curid=5687346", "extmetadata": {"DateTime": {"value": "2009-01-11 01:22:15", "source": "mediawiki-metadata", "hidden": ""}, "ObjectName": {"value": "Darwin restored2", "source": "mediawiki-metadata"}, "CommonsMetadataExtension": {"value": 1.2, "source": "extension", "hidden": ""}, "Categories": {"value": "Images from the Library of Congress|PD-Bain|Elliott & Fry|Portraits of Charles Darwin|Featured pictures on Wikipedia, Persian|Featured pictures on Wikipedia, Turkish|Formerly featured pictures on Wikipedia, English|1879 portrait photographs|Library of Congress-no known copyright restrictions|Files with Assessments template missing SDC Commons no value quality assessment", "source": "commons-categories", "hidden": ""}, "Assessments": {"value": "", "source": "commons-categories", "hidden": ""}, "ImageDescription": {"value": "<p><a href=\"https://en.wikipedia.org/wiki/Charles_Darwin\" class=\"extiw\" title=\"w:Charles Darwin\">Charles Darwin</a>.  1 negative : glass ; 5 x 7 in. or smaller.  From a <a rel=\"nofollow\" class=\"external text\" href=\"http://darwin-online.org.uk/content/frameset?itemID=A162&amp;viewtype=image&amp;pageseq=533\">photograph</a> by <a href=\"https://en.wikipedia.org/wiki/Elliott_%26_Fry\" class=\"extiw\" title=\"w:Elliott &amp; Fry\">Elliott &amp; Fry</a>.  According to Gene Kritsky, maintainer of an archive of Darwin photographs, this was from a photography session at Darwin's home, <a href=\"https://en.wikipedia.org/wiki/Down_House\" class=\"extiw\" title=\"w:Down House\">Down House</a>, and on another photograph from that session Darwin wrote \"1879\" on the back.  It was later widely sold and distributed on heavy card stock by Elliott &amp; Fry, with a caption dating it \"Circa 1880\".  It was later reproduced in a wide range of <a rel=\"nofollow\" class=\"external text\" href=\"http://jadepricephoto.com/darwiniana/index.htm\">Darwiniana</a>.\n</p>\nHowever, <a rel=\"nofollow\" class=\"external text\" href=\"https://images.hollis.harvard.edu/primo-explore/viewcomponent/L/HVD_VIAFAL28852?vid=HVD_IMAGES&amp;imageId=urn-3:HUAM:INV126353_mddl\">Harvard dates the same photo to 1874</a>.", "source": "commons-desc-page"}, "DateTimeOriginal": {"value": "1874", "source": "commons-desc-page"}, "Credit": {"value": "Library of Congress<a rel=\"nofollow\" class=\"external autonumber\" href=\"https://hdl.loc.gov/loc.pnp/ggbain.03485\">[1]</a>", "source": "commons-desc-page"}, "Artist": {"value": "<bdi><a href=\"https://en.wikipedia.org/wiki/Elliott_%26_Fry\" class=\"extiw\" title=\"w:Elliott &amp; Fry\">Elliott &amp; Fry</a></bdi>", "source": "commons-desc-page"}, "LicenseShortName": {"value": "Public domain", "source": "commons-desc-page", "hidden": ""}, "UsageTerms": {"value": "Public domain", "source": "commons-desc-page"}, "AttributionRequired": {"value": "false", "source": "commons-desc-page", "hidden": ""}, "Copyrighted": {"value": "False", "source": "commons-desc-page", "hidden": ""}, "Restrictions": {"value": "", "source": "commons-desc-page", "hidden": ""}, "License": {"value": "pd", "source": "commons-templates", "hidden": ""}}, "mime": "image/jpeg"}]}}}}