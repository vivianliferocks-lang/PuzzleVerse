{"continue": {"iistart": "2007-11-22T10:53:33Z", "continue": "||"}, "query": {"pages": {"3128528": {"pageid": 3128528, "ns": 6, "title": "File:Galileo Pendulum Clock.jpg", "imagerepository": "local", "imageinfo": [{"size": 14319, "width": 250, "height": 401, "canonicaltitle": "File:Galileo Pendulum Clock.jpg", "url": "https://upload.wikimedia.org/wikipedia/commons/8/8c/Galileo_Pendulum_Clock.jpg", "descriptionurl": "https://commons.wikimedia.org/wiki/File:Galileo_Pendulum_Clock.jpg", "descriptionshorturl": "https://commons.wikimedia.org/w/index.php?curid=3128528", "extmetadata": {"DateTime": {"value": "2021-05-03 15:43:39", "source": "mediawiki-metadata", "hidden": ""}, "ObjectName": {"value": "Galileo Pendulum Clock", "source": "mediawiki-metadata"}, "CommonsMetadataExtension": {"value": 1.2, "source": "extension", "hidden": ""}, "Categories": {"value": "Clockworks|PD-Art (PD-old)|CC-PD-Mark|Old horology prints|PD-Art missing SDC copyright status|PD-old missing SDC copyright status|Gallileo's escapement", "source": "commons-categories", "hidden": ""}, "Assessments": {"value": "", "source": "commons-categories", "hidden": ""}, "ImageDescription": {"value": "Drawing of <a href=\"https://en.wikipedia.org/wiki/pendulum_clock\" class=\"extiw\" title=\"wikipedia:pendulum clock\">pendulum clock</a> designed by <a href=\"https://en.wikipedia.org/wiki/Galileo_Galilei\" class=\"extiw\" title=\"wikipedia:Galileo Galilei\">Galileo Galilei</a> around 1641.  Part of the front supporting plate is removed by the artist to show the wheelwork.  Although the source says the drawing is 'by' Galileo, it is undoubtedly the one drawn by his student Vincenzo Viviani in 1659, since Galileo was blind by the time he had the idea.  Probably the first design for a pendulum clock, it was partly constructed by Galileo's son, who died before he could finish it.  For more information see Al Van Helden (1995), <a rel=\"nofollow\" class=\"external text\" href=\"http://galileo.rice.edu/sci/instruments/pendulum.html\">Pendulum Clock, The Galileo Project</a>.  Alterations to image: none.", "source": "commons-desc-page"}, "DateTimeOriginal": {"value": "drawn in 1659", "source": "commons-desc-page"}, "Credit": {"value": "downloaded from George Rieke, <a rel=\"nofollow\" class=\"external text\" href=\"http://ircamera.as.arizona.edu/NatSci102/NatSci102/lectures/galileo.htm\">Galileo, Natural Sciences 102 syllabus</a>, Univ. of Arizona", "source": "commons-desc-page"}, "Artist": {"value": "Vincenzo Viviani", "source": "commons-desc-page"}, "Permission": {"value": "Public domain - Galileo died in 1642, Viviani died in 1703", "source": "commons-desc-page", "hidden": ""}, "LicenseShortName": {"value": "Public domain", "source": "commons-desc-page", "hidden": ""}, "UsageTerms": {"value": "Public domain", "source": "commons-desc-page"}, "AttributionRequired": {"value": "false", "source": "commons-desc-page", "hidden": ""}, "Copyrighted": {"value": "False", "source": "commons-desc-page", "hidden": ""}, "Restrictions": {"value": "", "source": "commons-desc-page", "hidden": ""}, "License": {"value": "pd", "source": "commons-templates", "hidden": ""}}, "mime": "image/jpeg"}]}}}}