{"continue": {"iistart": "2015-05-14T11:21:30Z", "continue": "||"}, "query": {"pages": {"40199451": {"pageid": 40199451, "ns": 6, "title": "File:E pur si muove.jpg", "imagerepository": "local", "imageinfo": [{"size": 770878, "width": 1500, "height": 1780, "canonicaltitle": "File:E pur si muove.jpg", "url": "https://upload.wikimedia.org/wikipedia/commons/0/06/E_pur_si_muove.jpg", "descriptionurl": "https://commons.wikimedia.org/wiki/File:E_pur_si_muove.jpg", "descriptionshorturl": "https://commons.wikimedia.org/w/index.php?curid=40199451", "extmetadata": {"DateTime": {"value": "2021-04-06 05:44:53", "source": "mediawiki-metadata", "hidden": ""}, "ObjectName": {"value": "<div class=\"fn\">\n<div style=\"font-weight:bold;display:inline-block;\"><div style=\"display:inline-block\" dir=\"ltr\" lang=\"en\"><i><a href=\"//commons.wikimedia.org/wiki/Galileo_Galilei\" title=\"Galileo Galilei\">Galileo</a> in prison</i></div></div><div style=\"display: none;\">label QS:Len,\"<a href=\"//commons.wikimedia.org/wiki/Galileo_Galilei\" title=\"Galileo Galilei\">Galileo</a> in prison\"</div><div style=\"display: none;\">label QS:Lfr,\"Galilée en prison\"</div></div>", "source": "commons-desc-page"}, "CommonsMetadataExtension": {"value": 1.2, "source": "extension", "hidden": ""}, "Categories": {"value": "PD-old-100-expired|PD-Art (PD-old-100-expired)|CC-PD-Mark|Paintings without Wikidata item|Paintings of Galileo Galilei|Paintings by Eugène van Maldeghem", "source": "commons-categories", "hidden": ""}, "Assessments": {"value": "", "source": "commons-categories", "hidden": ""}, "Artist": {"value": "<div class=\"fn value\">\n<p>unknown. One of its former owners had attributed it to <a href=\"https://en.wikipedia.org/wiki/Bartolom%C3%A9_Esteban_Murillo\" class=\"extiw\" title=\"w:Bartolomé Esteban Murillo\">Bartolomé Esteban Murillo</a>, but recent investigations have cast doubt on that attribution.<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">[</span>1<span class=\"cite-bracket\">]</span></a></sup><br>\n</p>\n<ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">↑</a></span> <span class=\"reference-text\">Livio, Mario (<span class=\"mw-formatted-date\" title=\"2020-05-06\">May 6, 2020</span>) <cite>, <a rel=\"nofollow\" class=\"external text\" href=\"https://blogs.scientificamerican.com/observations/did-galileo-truly-say-and-yet-it-moves-a-modern-detective-story/\">Did Galileo Truly Say, ‘And Yet It Moves’? A Modern Detective Story</a></cite></span>\n</li>\n</ol></div>", "source": "commons-desc-page"}, "ImageDescription": {"value": "Galileo is depicted as holding a nail and gazing at diagrams he has scratched on the wall of his prison cell.  The words \"E pur si muove\" (only partially legible in this image) appear on the wall below a diagram of the Earth orbiting the Sun.", "source": "commons-desc-page"}, "DateTimeOriginal": {"value": "19th century (estimated)", "source": "commons-desc-page"}, "Credit": {"value": "<a rel=\"nofollow\" class=\"external text\" href=\"https://blogs.scientificamerican.com/observations/did-galileo-truly-say-and-yet-it-moves-a-modern-detective-story/\">Campo &amp; Campo auction house</a>", "source": "commons-desc-page"}, "Permission": {"value": "<table cellspacing=\"8\" cellpadding=\"0\" style=\"clear:both; margin:0.5em auto; background-color: var(--background-color-interactive, #f0f0f0); color: inherit; border: 2px solid var(--border-color-subtle, #e0e0e0); width:100%;\" class=\"layouttemplate\" dir=\"ltr\" lang=\"en\">\n<tbody><tr>\n<td>\n<div class=\"center\">This is a faithful photographic reproduction of a two-dimensional, <a href=\"//commons.wikimedia.org/wiki/Public_domain\" class=\"mw-redirect\" title=\"Public domain\">public domain</a> work of art. The work of art itself is in the public domain for the following reason:</div>\n<div dir=\"auto\">\n<table class=\"licensetpl\" style=\"display:none\">\n<tbody><